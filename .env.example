# The Odds API — free tier: 500 requests/month
# Sign up at https://the-odds-api.com to get your key
# Server-only (NOT prefixed with VITE_ — stays out of the browser bundle)
ODDS_API_KEY=

# Supabase — used for cron-synced picks storage
# Get these from your Supabase project → Settings → API
SUPABASE_URL=
# Use a server-only elevated key here. New `sb_secret_...` keys are valid.
SUPABASE_SERVICE_ROLE_KEY=
# Optional aliases accepted by the server if Render already has one saved:
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_KEY=

# Cron secret — protects the /api/sync endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=
